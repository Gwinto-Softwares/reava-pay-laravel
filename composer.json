{
    "name": "reava-pay/laravel",
    "description": "Official Laravel package for the Reava Pay payment gateway — Admin UI, webhooks, transaction tracking, one-click connect",
    "keywords": ["reava-pay", "laravel", "payments", "mpesa", "mobile-money", "africa"],
    "homepage": "https://reavapay.com/developers",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Reava Pay",
            "email": "developers@reavapay.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/encryption": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "ReavaPay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ReavaPay\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ReavaPay\\LaravelServiceProvider"
            ],
            "aliases": {
                "ReavaPay": "ReavaPay\\Facades\\ReavaPay"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
